# ============================================================
# demo.env.example — Copy to demo.env and fill in your values.
# Generated by deploy_apim.sh — this example shows all required vars.
# ============================================================

# ── OpenAI routing ────────────────────────────────────────
# APIM Standard v2 gateway — routes through Prisma AIRS scanning policy.
# APIM uses its system-assigned MSI to authenticate to Azure OpenAI.
# The backend authenticates to APIM anonymously (subscriptionRequired=false).
OPENAI_HOST=azure_custom
AZURE_OPENAI_CUSTOM_URL=https://<your-apim-name>.azure-api.net/openai/v1
AZURE_OPENAI_SERVICE=<your-openai-account-name>
AZURE_OPENAI_CHATGPT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_CHATGPT_MODEL=gpt-4o
AZURE_OPENAI_EMB_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMB_MODEL_NAME=text-embedding-ada-002

# ── Azure AI Search ───────────────────────────────────────
# Set AZURE_SEARCH_SERVICE to enable RAG mode.
# Leave blank to use DirectChatApproach (no RAG) — suitable for this POV.
AZURE_SEARCH_SERVICE=
AZURE_SEARCH_INDEX=
AZURE_SEARCH_KEY=<your-search-admin-key>
# Private endpoint IP — used by start_demo.sh to patch /etc/hosts if needed
SEARCH_PRIVATE_IP=<private-ip-from-private-endpoint>

# ── Azure Storage ─────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=<your-storage-account-name>
AZURE_STORAGE_CONTAINER=content
AZURE_STORAGE_KEY=<your-storage-account-key>

# ── Prisma AIRS ───────────────────────────────────────────
PRISMA_AIRS_API_KEY=<your-prisma-airs-api-key>
PRISMA_AIRS_PROFILE_NAME=<your-airs-security-profile-name>

# ── App Config ────────────────────────────────────────────
AZURE_OPENAI_RESOURCE_GROUP=<your-resource-group>
AZURE_TENANT_ID=<your-aad-tenant-id>

# ── For show_apim_traffic.py ──────────────────────────────
APIM_GATEWAY_URL=https://<your-apim-name>.azure-api.net
# Master subscription key — only needed by test scripts (API itself has no subscription requirement)
APIM_SUBSCRIPTION_KEY=<your-apim-master-subscription-key>

# ── Log Analytics (added by setup_monitoring.sh) ──────────────────
LAW_WORKSPACE_ID=<log-analytics-workspace-id>
LAW_RESOURCE_ID=<log-analytics-resource-id>
